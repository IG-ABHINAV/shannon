# Shannon Environment Configuration
# Copy this file to .env if you want to override the default Codex model/runtime.
# Authentication comes from your local Codex CLI login (`codex login`), not from
# API keys in this file.

# Default Codex model used by Shannon.
SHANNON_CODEX_MODEL=gpt-5.4

# Reasoning effort passed to Codex CLI. Supported values depend on the model.
# Common values: low, medium, high, xhigh
SHANNON_CODEX_REASONING_EFFORT=high

# Optional override if your Codex home is not at ~/.codex.
# CODEX_HOME_HOST=/absolute/path/to/your/.codex
